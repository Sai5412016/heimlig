{
  "expo": {
    "name": "heimlig",
    "slug": "heimlig",
    "scheme": "heimlig",
    "version": "1.0.2",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D6A4F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.fledderman.heimlig",
      "versionCode": 51,
      "googleServicesFile": "./google-services.json",
      "permissions": ["NOTIFICATIONS", "RECEIVE_BOOT_COMPLETED", "VIBRATE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      ["expo-notifications", {
        "icon": "./assets/icon.png",
        "color": "#2D6A4F"
      }],
      ["expo-image-picker", {
        "photosPermission": "Heimlig braucht Zugriff auf deine Fotos, um Zutaten aus Rezept-Screenshots zu erkennen."
      }],
      ["expo-camera", {
        "cameraPermission": "Heimlig braucht Zugriff auf die Kamera, um Produkt-Barcodes zu scannen."
      }],
      ["expo-location", {
        "locationWhenInUsePermission": "Heimlig teilt deinen Standort nur, wenn du auf „Standort teilen“ tippst – für deine Haushaltsmitglieder."
      }],
      ["react-native-android-widget", {
        "widgets": [{
          "name": "Heimlig",
          "label": "Heimlig",
          "description": "Aufgaben & Einkauf auf einen Blick",
          "minWidth": "180dp",
          "minHeight": "110dp",
          "targetCellWidth": 3,
          "targetCellHeight": 2,
          "updatePeriodMillis": 1800000
        }]
      }],
      ["@sentry/react-native/expo", {
        "organization": "gut-feeling-labs",
        "project": "react-native"
      }]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8a17131d-7504-488b-a52b-81b0414105b1"
      }
    }
  }
}
